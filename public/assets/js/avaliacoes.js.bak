    var normalizeSearchValue = deps && typeof deps.normalizeSearchValue === 'function'
      ? deps.normalizeSearchValue
      : function (value) {
        return String(value || '')
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim();
      };

